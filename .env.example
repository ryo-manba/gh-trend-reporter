# gh-trend-reporter 環境変数設定
# このファイルを .env にコピーして値を設定してください

# --- 必須 ---
# Gemini API キー（Google AI Studio で取得）
GEMINI_API_KEY=your_gemini_api_key

# --- 任意 ---
# GitHub Personal Access Token（未設定でも動作するがレート制限が 60 req/h に低下）
# 注意: 無効な値を設定すると 401 Unauthorized エラーになります。
#       使わない場合はコメントアウトのままにしてください。
# GITHUB_TOKEN=your_github_pat

# --- アプリケーション設定（すべて任意） ---
# SQLite データベースファイルのパス
# GTR_DB_PATH=./data/trends.db

# レポート出力ディレクトリ
# GTR_REPORTS_DIR=./reports

# スクレイピング時のリクエスト間隔（秒）
# GTR_COLLECT_INTERVAL=2.0

# リポジトリ詳細キャッシュの有効期限（秒）
# GTR_CACHE_TTL=86400

# エージェントループの最大ターン数
# GTR_AGENT_MAX_TURNS=10
